{
  "name": "proofpitch",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "release:deck:export": "slidev export .proofpitch/release-assets/latest/pitch-deck.md --format pdf --output .proofpitch/release-assets/latest/pitch-deck.pdf",
    "release:video:browser-record": "node scripts/record-real-frontend-demo.mjs",
    "release:video:hyperframes:studio": "npm --prefix hyperframes/proofpitch-demo run dev",
    "release:video:hyperframes:check": "npm --prefix hyperframes/proofpitch-demo run check",
    "release:video:hyperframes:render": "npm --prefix hyperframes/proofpitch-demo run render -- --output ../../public/demo/proofpitch-hyperframes-demo.mp4 --quality standard --workers 1",
    "release:render:local": "node scripts/render-release-artifacts.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@slidev/cli": "^52.15.2",
    "@slidev/theme-default": "^0.25.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "hyperframes": "^0.6.13",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "playwright-chromium": "^1.60.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "^22.1.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.6"
  }
}
