# Required for the first real generation path.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# P0 provider integrations. The app still returns a release pack when these are empty.
TAVILY_API_KEY=
FAL_KEY=
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=verse

# P1 provider integrations.
GRADIUM_API_KEY=
PIONEER_API_KEY=
PIONEER_MODEL_ID=fastino/gliner2-base-v1

# Release Pack capture and local rendering. The Playwright/Remotion paths are intended for a worker environment.
PROOFPITCH_PLAYWRIGHT_CAPTURE=0
PROOFPITCH_RELEASE_ASSET_DIR=.proofpitch/release-assets
PROOFPITCH_ENABLE_LOCAL_RENDER=0
NEXT_PUBLIC_SITE_URL=

# Review-gated channel publishing. Callback token storage is still gated for prod hardening.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=

# Supabase is optional locally. When these are empty, API routes use an in-memory store.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Billing defaults to manual locally. Set Stripe test keys and price IDs to enable checkout.
BILLING_MODE=manual
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_FOUNDER_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_AGENCY_PRICE_ID=
STRIPE_SINGLE_PRICE_ID=
PROOFPITCH_LOCAL_DEMO_PACK_LIMIT=1000
PROOFPITCH_FREE_PACK_LIMIT=1
PROOFPITCH_FOUNDER_PACK_LIMIT=10
PROOFPITCH_PRO_PACK_LIMIT=40
PROOFPITCH_AGENCY_PACK_LIMIT=150
PROOFPITCH_ENTERPRISE_PACK_LIMIT=1000
