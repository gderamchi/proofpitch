# Core generation.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# MVP proof providers. The app still returns a deterministic demo brief when these are empty.
TAVILY_API_KEY=
PIONEER_API_KEY=
PIONEER_MODEL_ID=fastino/gliner2-base-v1
GRADIUM_API_KEY=
GRADIUM_VOICE_ID=

# Product demo capture and local rendering. Playwright capture should run in a worker-capable environment.
PROOFPITCH_PLAYWRIGHT_CAPTURE=0
PROOFPITCH_VIDEO_ASSET_DIR=.proofpitch/demo-video-assets
PROOFPITCH_ENABLE_LOCAL_RENDER=0
NEXT_PUBLIC_SITE_URL=

# Supabase is optional locally. When these are empty, API routes use an in-memory store.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
