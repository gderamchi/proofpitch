# Core generation.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# MVP proof providers. The app still returns a deterministic pack when these are empty.
TAVILY_API_KEY=
PIONEER_API_KEY=
PIONEER_MODEL_ID=fastino/gliner2-base-v1
GRADIUM_API_KEY=
GRADIUM_VOICE_ID=YTpq7expH9539ERJ
FAL_KEY=

# Product demo capture and local rendering. Playwright capture should run in a worker-capable environment.
PROOFPITCH_PLAYWRIGHT_CAPTURE=0
PROOFPITCH_RELEASE_ASSET_DIR=.proofpitch/release-assets
PROOFPITCH_ENABLE_LOCAL_RENDER=0
NEXT_PUBLIC_SITE_URL=

# Supabase is optional locally. When these are empty, API routes use an in-memory store.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe test or live mode. Use test keys until go-live validation is complete.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_FOUNDER_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_AGENCY_PRICE_ID=
STRIPE_SINGLE_PRICE_ID=
BILLING_MODE=manual

# Local quota defaults.
PROOFPITCH_LOCAL_DEMO_PACK_LIMIT=1000
PROOFPITCH_FREE_PACK_LIMIT=1
PROOFPITCH_FOUNDER_PACK_LIMIT=10
PROOFPITCH_PRO_PACK_LIMIT=40
PROOFPITCH_AGENCY_PACK_LIMIT=150
PROOFPITCH_ENTERPRISE_PACK_LIMIT=1000
